<div class="floating-stack">
  <a class="fab fab-whatsapp" href="https://wa.me/919999999999" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.71.45 3.38 1.3 4.85L2.05 22l5.36-1.35c1.4.76 2.98 1.16 4.6 1.16h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0012.04 2zm0 18.06h-.01c-1.44 0-2.85-.39-4.08-1.12l-.29-.17-3.02.77.8-2.94-.19-.3a8.03 8.03 0 01-1.24-4.31c0-4.47 3.65-8.11 8.13-8.11 2.17 0 4.2.85 5.74 2.38a8.05 8.05 0 012.38 5.75c0 4.47-3.65 8.05-8.22 8.05zm4.46-6.02c-.24-.12-1.44-.71-1.67-.79-.22-.08-.39-.12-.55.12-.16.24-.63.79-.78.95-.14.16-.29.18-.53.06-.24-.12-1.03-.38-1.96-1.21-.72-.65-1.21-1.44-1.35-1.68-.14-.24-.02-.37.11-.49.11-.11.24-.29.36-.43.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.33-.76-1.82-.2-.48-.4-.42-.55-.42-.14-.01-.3-.01-.46-.01-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.12 3.64.58.25 1.03.4 1.38.51.58.18 1.11.16 1.53.1.47-.07 1.44-.59 1.64-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28z"/></svg>
  </a>
  <button class="fab fab-cart" id="fabCartBtn" aria-label="Open cart">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"></path></svg>
    <span class="fab-badge" id="fabCartBadge" style="display:none;">0</span>
  </button>
</div>

<!-- ===== Overlay ===== -->
<div class="overlay" id="overlay"></div>

<!-- ===== Cart Drawer ===== -->
<div class="drawer" id="cartDrawer" aria-label="Shopping cart">
  <div class="drawer-header">
    <h3>Your Cart</h3>
    <button class="close-btn" id="closeCartBtn" aria-label="Close cart">✕</button>
  </div>
  <div class="drawer-body" id="cartDrawerBody">
    <!-- filled by JS -->
  </div>
  <div class="drawer-footer" id="cartDrawerFooter">
    <!-- filled by JS -->
  </div>
</div>

<!-- ===== Checkout Drawer ===== -->
<div class="drawer" id="checkoutDrawer" aria-label="Checkout">
  <div class="drawer-header">
    <h3>Place Order</h3>
    <button class="close-btn" id="closeCheckoutBtn" aria-label="Close checkout">✕</button>
  </div>
  <div class="drawer-body" id="checkoutDrawerBody">
    <!-- filled by JS -->
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
(function(){
  "use strict";

  /* =========================================================
     SHOP CONFIG — edit this block to rebrand the whole site
  ========================================================= */
  const SHOP = {
    name: "Raj Electronic",
    tagline: "Electronic products",
    location: "Varanasi, UP",
    phone: "919999999999",          // WhatsApp / call number, country code no plus/spaces
    email: "techraj2006@gmail.com",
    formspreeEndpoint: "https://formspree.io/f/YOUR_FORM_ID" // <-- replace with your real Formspree form ID
  };

  /* =========================================================
     PRODUCTS — add/remove/edit items here
  ========================================================= */
  const PRODUCTS = [
    {
      id: "p1",
      name: "Wireless Mic",
      price: 2600,
      category: "electronic",
      img: "https://i.ibb.co/JWw7DKct/IMG-20260712-170738.jpg",
      desc: "Premium wireless mic"
    },
    {
      id: "p2",
      name: "Bluetooth Mini Speaker",
      price: 500,
      category: "electronic",
      img: "https://i.ibb.co/xn4JFxP/IMG-20260712-170757.jpg",
      desc: "Mini but powerful 💪"
    },
    {
      id: "p3",
      name: "Hand Watch",
      price: 500,
      category: "electronic",
      img: "https://i.ibb.co/7tkJVhWK/IMG-20260712-170805.jpg",
      desc: "Premium hand watch ⌚"
    }
  ];

  const money = n => "₹" + Number(n).toLocaleString("en-IN");

  /* =========================================================
     STATE
  ========================================================= */
  let cart = {}; // { productId: qty }
  try {
    cart = JSON.parse(localStorage.getItem("rajElectronicCart") || "{}");
  } catch(e){ cart = {}; }

  let activeCategory = "all";

  function saveCart(){
    localStorage.setItem("rajElectronicCart", JSON.stringify(cart));
    renderCartBadges();
  }

  function cartCount(){
    return Object.values(cart).reduce((a,b)=>a+b, 0);
  }

  function cartLines(){
    return Object.entries(cart)
      .map(([id, qty]) => {
        const p = PRODUCTS.find(x => x.id === id);
        if(!p) return null;
        return { ...p, qty, lineTotal: p.price * qty };
      })
      .filter(Boolean);
  }

  function cartTotal(){
    return cartLines().reduce((sum, l) => sum + l.lineTotal, 0);
  }

  /* =========================================================
     RENDER: Filter bar
  ========================================================= */
  function getCategories(){
    const cats = Array.from(new Set(PRODUCTS.map(p => p.category)));
    return ["all", ...cats];
  }

  function renderFilters(){
    const bar = document.getElementById("filterBar");
    bar.innerHTML = "";
    getCategories().forEach(cat => {
      const btn = document.createElement("button");
      btn.className = "chip" + (cat === activeCategory ? " active" : "");
      btn.textContent = cat === "all" ? "All Products" : cat.charAt(0).toUpperCase() + cat.slice(1);
      btn.addEventListener("click", () => {
        activeCategory = cat;
        renderFilters();
        renderGrid();
      });
      bar.appendChild(btn);
    });
  }

  /* =========================================================
     RENDER: Product grid
  ========================================================= */
  function renderGrid(){
    const grid = document.getElementById("productGrid");
    const empty = document.getElementById("emptyState");
    const list = activeCategory === "all" ? PRODUCTS : PRODUCTS.filter(p => p.category === activeCategory);

    document.getElementById("resultCount").textContent = list.length + (list.length === 1 ? " item" : " items");

    grid.innerHTML = "";
    if(list.length === 0){
      empty.style.display = "block";
      return;
    }
    empty.style.display = "none";

    list.forEach(p => {
      const card = document.createElement("div");
      card.className = "card";
      card.innerHTML = `
        <div class="card-img">
          <span class="card-cat">${escapeHtml(p.category)}</span>
          <img src="${escapeAttr(p.img)}" alt="${escapeAttr(p.name)}" loading="lazy">
        </div>
        <div class="card-body">
          <h4>${escapeHtml(p.name)}</h4>
          <div class="desc">${escapeHtml(p.desc)}</div>
          <div class="card-footer">
            <span class="price">${money(p.price)}</span>
            <button class="add-btn" data-id="${p.id}">Add to Cart</button>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });

    grid.querySelectorAll(".add-btn").forEach(btn => {
      btn.addEventListener("click", () => addToCart(btn.dataset.id, btn));
    });
  }

  function escapeHtml(str){
    return String(str).replace(/[&<>"']/g, s => ({
      "&":"&amp;", "<":"&lt;", ">":"&gt;", '"':"&quot;", "'":"&#39;"
    }[s]));
  }
  function escapeAttr(str){ return escapeHtml(str); }

  /* =========================================================
     CART ACTIONS
  ========================================================= */
  function addToCart(id, btnEl){
    cart[id] = (cart[id] || 0) + 1;
    saveCart();
    showToast("Added to cart");
    if(btnEl){
      btnEl.classList.add("added");
      btnEl.textContent = "Added ✓";
      setTimeout(() => {
        btnEl.classList.remove("added");
        btnEl.textContent = "Add to Cart";
      }, 900);
    }
    if(document.getElementById("cartDrawer").classList.contains("open")){
      renderCartDrawer();
    }
  }

  function changeQty(id, delta){
    if(!cart[id]) return;
    cart[id] += delta;
    if(cart[id] <= 0) delete cart[id];
    saveCart();
    renderCartDrawer();
  }

  function removeItem(id){
    delete cart[id];
    saveCart();
    renderCartDrawer();
  }

  function renderCartBadges(){
    const count = cartCount();
    [document.getElementById("headerCartBadge"), document.getElementById("fabCartBadge")].forEach(el => {
      if(count > 0){
        el.style.display = "flex";
        el.textContent = count;
      } else {
        el.style.display = "none";
      }
    });
  }

  /* =========================================================
     RENDER: Cart Drawer
  ========================================================= */
  function renderCartDrawer(){
    const body = document.getElementById("cartDrawerBody");
    const footer = document.getElementById("cartDrawerFooter");
    const lines = cartLines();

    if(lines.length === 0){
      body.innerHTML = `<div class="empty-state">Your cart is empty.<br><br>Add some products to get started!</div>`;
      footer.innerHTML = "";
      return;
    }

    body.innerHTML = lines.map(l => `
      <div class="cart-item" data-id="${l.id}">
        <img src="${escapeAttr(l.img)}" alt="${escapeAttr(l.name)}" loading="lazy">
        <div class="cart-item-info">
          <h5>${escapeHtml(l.name)}</h5>
          <div class="unit-price">${money(l.price)} each</div>
          <div class="qty-row">
            <button class="qty-btn" data-action="minus" data-id="${l.id}">−</button>
            <span class="qty-val">${l.qty}</span>
            <button class="qty-btn" data-action="plus" data-id="${l.id}">+</button>
            <button class="remove-link" data-action="remove" data-id="${l.id}">Remove</button>
          </div>
        </div>
        <div class="cart-item-total">${money(l.lineTotal)}</div>
      </div>
    `).join("");

    const total = cartTotal();
    footer.innerHTML = `
      <div class="totals-row grand"><span>Total</span><span class="amt">${money(total)}</span></div>
      <button class="full-btn" id="proceedCheckoutBtn" style="margin-top:12px;">Proceed to Checkout →</button>
    `;

    body.querySelectorAll("[data-action]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.id;
        const action = btn.dataset.action;
        if(action === "plus") changeQty(id, 1);
        if(action === "minus") changeQty(id, -1);
        if(action === "remove") removeItem(id);
      });
    });

    const proceedBtn = document.getElementById("proceedCheckoutBtn");
    if(proceedBtn){
      proceedBtn.addEventListener("click", () => {
        closeCart();
        openCheckout();
      });
    }
  }

  /* =========================================================
     RENDER: Checkout Drawer
  ========================================================= */
  function renderCheckoutForm(){
    const body = document.getElementById("checkoutDrawerBody");
    const lines = cartLines();
    const total = cartTotal();

    if(lines.length === 0){
      body.innerHTML = `<div class="empty-state">Your cart is empty.<br><br>Add products before checking out.</div>`;
      return;
    }

    body.innerHTML = `
      <div class="order-summary-box">
        ${lines.map(l => `
          <div class="line"><span>${escapeHtml(l.name)} × ${l.qty}</span><b>${money(l.lineTotal)}</b></div>
        `).join("")}
        <div class="line" style="border-top:1px dashed var(--line); margin-top:6px; padding-top:8px;">
          <span>Grand Total</span><b>${money(total)}</b>
        </div>
      </div>

      <form id="orderForm">
        <div class="form-field">
          <label>Customer Name <span class="req">*</span></label>
          <input type="text" name="customer_name" required placeholder="Your full name">
        </div>
        <div class="form-field">
          <label>Phone Number <span class="req">*</span></label>
          <input type="tel" name="customer_phone" required placeholder="10-digit mobile number" pattern="[0-9+\\s-]{7,15}">
        </div>
        <div class="form-field">
          <label>Delivery Address <span class="req">*</span></label>
          <textarea name="customer_address" required placeholder="House no, street, area, landmark, city, pincode"></textarea>
        </div>
        <div class="form-field">
          <label>Special Instructions (optional)</label>
          <textarea name="customer_notes" placeholder="Anything else we should know?"></textarea>
        </div>

        <!-- Hidden fields: full readable order summary for the email -->
        <input type="hidden" name="_subject" value="New Order — ${SHOP.name}">
        <input type="hidden" name="order_items_summary" id="order_items_summary">
        <input type="hidden" name="order_grand_total" id="order_grand_total">
        <input type="hidden" name="full_order_email_body" id="full_order_email_body">

        <button type="submit" class="full-btn" id="placeOrderBtn">Place Order — ${money(total)}</button>
      </form>
    `;

    // Build machine + human readable hidden summary fields
    const itemsSummary = lines.map(l => `${l.name} x${l.qty} @ ${money(l.price)} = ${money(l.lineTotal)}`).join("\n");
    document.getElementById("order_items_summary").value = itemsSummary;
    document.getElementById("order_grand_total").value = money(total);

    const form = document.getElementById("orderForm");
    form.addEventListener("submit", handleOrderSubmit);
  }

  function buildFullEmailBody(formData, lines, total){
    const name = formData.get("customer_name");
    const phone = formData.get("customer_phone");
    const address = formData.get("customer_address");
    const notes = formData.get("customer_notes") || "(none)";

    let body = `NEW ORDER — ${SHOP.name}\n`;
    body += `============================\n\n`;
    body += `ITEMS ORDERED:\n`;
    lines.forEach(l => {
      body += `- ${l.name}  |  Qty: ${l.qty}  |  Price: ${money(l.price)}  |  Subtotal: ${money(l.lineTotal)}\n`;
    });
    body += `\nGRAND TOTAL: ${money(total)}\n`;
    body += `\n----------------------------\n`;
    body += `CUSTOMER DETAILS:\n`;
    body += `Name: ${name}\n`;
    body += `Phone: ${phone}\n`;
    body += `Address: ${address}\n`;
    body += `Special Instructions: ${notes}\n`;
    body += `\n----------------------------\n`;
    body += `Please contact the customer on WhatsApp/phone to confirm availability, pricing, and delivery.\n`;
    return body;
  }

  function handleOrderSubmit(e){
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById("placeOrderBtn");
    const lines = cartLines();
    const total = cartTotal();

    if(lines.length === 0){
      showToast("Your cart is empty");
      return;
    }

    const formData = new FormData(form);
    const fullBody = buildFullEmailBody(formData, lines, total);
    document.getElementById("full_order_email_body").value = fullBody;
    // Re-read formData since we just set a hidden field's value via DOM
    const finalData = new FormData(form);

    btn.disabled = true;
    btn.textContent = "Placing order…";

    const endpointConfigured = SHOP.formspreeEndpoint && !SHOP.formspreeEndpoint.includes("YOUR_FORM_ID");

    if(!endpointConfigured){
      // No real Formspree endpoint set up yet — simulate success so the shop owner can preview the flow,
      // but tell them clearly in the console what to fix.
      console.warn("Formspree endpoint not configured. Replace SHOP.formspreeEndpoint with your real form ID from formspree.io to actually receive order emails.");
      setTimeout(() => {
        showOrderSuccess();
      }, 600);
      return;
    }

    fetch(SHOP.formspreeEndpoint, {
      method: "POST",
      headers: { "Accept": "application/json" },
      body: finalData
    })
    .then(res => {
      if(res.ok){
        showOrderSuccess();
      } else {
        throw new Error("Form submission failed");
      }
    })
    .catch(err => {
      console.error(err);
      btn.disabled = false;
      btn.textContent = `Place Order — ${money(total)}`;
      showToast("Could not send order. Please try again or WhatsApp us directly.");
    });
  }

  function showOrderSuccess(){
    cart = {};
    saveCart();
    const body = document.getElementById("checkoutDrawerBody");
    body.innerHTML = `
      <div class="success-screen">
        <div class="success-icon">✓</div>
        <h4>Order placed!</h4>
        <p>${escapeHtml(SHOP.name)} will contact you on WhatsApp shortly to confirm your order, pricing, and delivery.</p>
        <a class="btn btn-primary" style="width:100%; justify-content:center;" href="https://wa.me/${SHOP.phone}" target="_blank" rel="noopener">
          Chat on WhatsApp Now
        </a>
        <button class="full-btn" style="margin-top:10px; background:var(--paper); color:var(--ink); border:1px solid var(--line);" id="continueShoppingBtn">
          Continue Shopping
        </button>
      </div>
    `;
    document.getElementById("continueShoppingBtn").addEventListener("click", () => {
      closeCheckout();
      renderGrid();
    });
  }

  /* =========================================================
     DRAWER OPEN/CLOSE
  ========================================================= */
  const overlay = document.getElementById("overlay");
  const cartDrawer = document.getElementById("cartDrawer");
  const checkoutDrawer = document.getElementById("checkoutDrawer");

  function openCart(){
    renderCartDrawer();
    cartDrawer.classList.add("open");
    overlay.classList.add("open");
  }
  function closeCart(){
    cartDrawer.classList.remove("open");
    if(!checkoutDrawer.classList.contains("open")) overlay.classList.remove("open");
  }
  function openCheckout(){
    renderCheckoutForm();
    checkoutDrawer.classList.add("open");
    overlay.classList.add("open");
  }
  function closeCheckout(){
    checkoutDrawer.classList.remove("open");
    if(!cartDrawer.classList.contains("open")) overlay.classList.remove("open");
  }

  document.getElementById("cartIconBtn").addEventListener("click", openCart);
  document.getElementById("fabCartBtn").addEventListener("click", openCart);
  document.getElementById("closeCartBtn").addEventListener("click", closeCart);
  document.getElementById("closeCheckoutBtn").addEventListener("click", closeCheckout);
  overlay.addEventListener("click", () => { closeCart(); closeCheckout(); });

  /* =========================================================
     TOAST
  ========================================================= */
  let toastTimer;
  function showToast(msg){
    const t = document.getElementById("toast");
    t.textContent = msg;
    t.classList.add("show");
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove("show"), 1800);
  }

  /* =========================================================
     INIT
  ========================================================= */
  // wire up WhatsApp/phone links from config (in case SHOP.phone edited)
  document.querySelectorAll('a[href^="https://wa.me/"]').forEach(a => {
    a.href = `https://wa.me/${SHOP.phone}`;
  });

  renderFilters();
  renderGrid();
  renderCartBadges();

})();
</script>
</body>
</html>
