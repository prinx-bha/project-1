<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raj Electronic — Electronic Products, Varanasi</title>
<meta name="description" content="Raj Electronic — quality electronic products in Varanasi, UP. Order online, pay on delivery.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0B1220;
    --navy:#10192E;
    --navy-2:#16223E;
    --paper:#F4F6FA;
    --card:#FFFFFF;
    --line:#E2E6EE;
    --amber:#FFB020;
    --amber-deep:#E89400;
    --green:#1E9E6B;
    --muted:#5B6577;
    --danger:#E24C4C;
    --radius:14px;
    --shadow: 0 8px 24px rgba(16,25,46,0.08);
    --shadow-lg: 0 20px 48px rgba(16,25,46,0.22);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Inter', sans-serif;
    background:var(--paper);
    color:var(--ink);
    -webkit-font-smoothing:antialiased;
    padding-bottom:70px;
  }
  h1,h2,h3, .display{ font-family:'Space Grotesk', sans-serif; }
  .mono{ font-family:'JetBrains Mono', monospace; letter-spacing:0.02em; }
  a{ color:inherit; text-decoration:none; }
  img{ max-width:100%; display:block; }
  button{ font-family:inherit; cursor:pointer; border:none; }

  /* ===== Circuit motif divider (signature element) ===== */
  .circuit-rule{
    height:14px;
    width:100%;
    background:
      linear-gradient(var(--amber), var(--amber)) left 0 top 6px / 100% 2px no-repeat;
    position:relative;
    margin: 0 0 0 0;
    opacity:0.9;
  }
  .circuit-rule::before, .circuit-rule::after{
    content:"";
    position:absolute; top:2px;
    width:10px; height:10px; border-radius:50%;
    background:var(--amber);
  }
  .circuit-rule::before{ left:6%; }
  .circuit-rule::after{ right:6%; }

  /* ===== Header ===== */
  header.site{
    background:var(--navy);
    color:#fff;
    padding:16px 20px;
    position:sticky;
    top:0;
    z-index:50;
    box-shadow:0 2px 12px rgba(0,0,0,0.15);
  }
  .header-inner{
    max-width:1100px;
    margin:0 auto;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
  }
  .brand{ display:flex; align-items:center; gap:12px; }
  .brand-mark{
    width:42px; height:42px;
    border-radius:10px;
    background:linear-gradient(135deg, var(--amber), var(--amber-deep));
    display:flex; align-items:center; justify-content:center;
    font-family:'Space Grotesk', sans-serif;
    font-weight:700;
    font-size:18px;
    color:var(--navy);
    flex-shrink:0;
  }
  .brand-text h1{ font-size:19px; font-weight:700; line-height:1.15; }
  .brand-text p{ font-size:11.5px; color:#B7C0D6; margin-top:2px; }
  .header-actions{ display:flex; align-items:center; gap:10px; }
  .icon-btn{
    background:rgba(255,255,255,0.08);
    color:#fff;
    width:40px; height:40px;
    border-radius:10px;
    display:flex; align-items:center; justify-content:center;
    position:relative;
    transition:background .15s ease;
  }
  .icon-btn:hover{ background:rgba(255,255,255,0.16); }
  .cart-badge{
    position:absolute;
    top:-6px; right:-6px;
    background:var(--amber);
    color:var(--navy);
    font-size:11px;
    font-weight:700;
    min-width:18px; height:18px;
    border-radius:9px;
    display:flex; align-items:center; justify-content:center;
    padding:0 4px;
    font-family:'JetBrains Mono', monospace;
  }

  /* ===== Hero ===== */
  .hero{
    position:relative;
    background:var(--navy);
    color:#fff;
    overflow:hidden;
  }
  .hero-inner{
    max-width:1100px;
    margin:0 auto;
    padding:36px 20px 44px;
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:28px;
    align-items:center;
  }
  .hero-copy .eyebrow{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:'JetBrains Mono', monospace;
    font-size:11.5px;
    color:var(--amber);
    background:rgba(255,176,32,0.1);
    border:1px solid rgba(255,176,32,0.35);
    padding:5px 10px;
    border-radius:20px;
    margin-bottom:14px;
  }
  .hero-copy .eyebrow::before{
    content:"";
    width:6px; height:6px;
    border-radius:50%;
    background:var(--green);
    box-shadow:0 0 0 3px rgba(30,158,107,0.25);
  }
  .hero-copy h2{
    font-size:clamp(26px, 4.2vw, 40px);
    line-height:1.08;
    font-weight:700;
    margin-bottom:12px;
  }
  .hero-copy h2 span{ color:var(--amber); }
  .hero-copy p{ color:#C7CFE2; font-size:15px; max-width:46ch; margin-bottom:20px; }
  .hero-ctas{ display:flex; gap:12px; flex-wrap:wrap; }
  .btn{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:12px 20px;
    border-radius:10px;
    font-weight:600;
    font-size:14.5px;
    transition:transform .12s ease, box-shadow .12s ease, background .12s ease;
  }
  .btn-primary{ background:var(--amber); color:var(--navy); }
  .btn-primary:hover{ transform:translateY(-2px); box-shadow:0 10px 20px rgba(255,176,32,0.25); }
  .btn-ghost{ background:rgba(255,255,255,0.08); color:#fff; border:1px solid rgba(255,255,255,0.2); }
  .btn-ghost:hover{ background:rgba(255,255,255,0.15); }
  .hero-image{
    position:relative;
    border-radius:18px;
    overflow:hidden;
    aspect-ratio:4/3;
    box-shadow:var(--shadow-lg);
    border:1px solid rgba(255,255,255,0.08);
  }
  .hero-image img{ width:100%; height:100%; object-fit:cover; }
  .hero-image::after{
    content:"";
    position:absolute; inset:0;
    background:linear-gradient(180deg, rgba(11,18,32,0) 55%, rgba(11,18,32,0.55) 100%);
  }
  @media (max-width:760px){
    .hero-inner{ grid-template-columns:1fr; padding:28px 18px 34px; }
    .hero-image{ order:-1; aspect-ratio:16/10; }
  }

  /* ===== Category filters ===== */
  .filters-wrap{
    background:var(--card);
    border-bottom:1px solid var(--line);
    position:sticky;
    top:74px;
    z-index:40;
  }
  .filters{
    max-width:1100px;
    margin:0 auto;
    padding:14px 20px;
    display:flex;
    gap:10px;
    overflow-x:auto;
    scrollbar-width:none;
  }
  .filters::-webkit-scrollbar{ display:none; }
  .chip{
    flex-shrink:0;
    padding:9px 16px;
    border-radius:999px;
    background:var(--paper);
    border:1px solid var(--line);
    font-size:13.5px;
    font-weight:600;
    color:var(--muted);
    transition:all .15s ease;
  }
  .chip.active{
    background:var(--navy);
    color:#fff;
    border-color:var(--navy);
  }
  .chip:hover:not(.active){ border-color:var(--amber-deep); color:var(--ink); }

  /* ===== Product grid ===== */
  main{ max-width:1100px; margin:0 auto; padding:28px 20px 40px; }
  .section-title{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    margin-bottom:16px;
  }
  .section-title h3{ font-size:20px; font-weight:700; }
  .section-title span{ font-size:12.5px; color:var(--muted); font-family:'JetBrains Mono', monospace; }

  .grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(200px, 1fr));
    gap:16px;
  }
  .card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:var(--radius);
    overflow:hidden;
    display:flex;
    flex-direction:column;
    transition:box-shadow .15s ease, transform .15s ease;
  }
  .card:hover{ box-shadow:var(--shadow); transform:translateY(-2px); }
  .card-img{
    aspect-ratio:1/1;
    background:var(--paper);
    position:relative;
    overflow:hidden;
  }
  .card-img img{ width:100%; height:100%; object-fit:cover; }
  .card-cat{
    position:absolute;
    top:8px; left:8px;
    background:rgba(11,18,32,0.75);
    color:#fff;
    font-size:10px;
    font-weight:600;
    padding:4px 8px;
    border-radius:6px;
    text-transform:uppercase;
    letter-spacing:0.04em;
  }
  .card-body{ padding:12px 14px 14px; display:flex; flex-direction:column; gap:6px; flex:1; }
  .card-body h4{ font-size:14.5px; font-weight:600; line-height:1.3; }
  .card-body .desc{ font-size:12.5px; color:var(--muted); line-height:1.4; flex:1; }
  .card-footer{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-top:6px;
  }
  .price{ font-family:'JetBrains Mono', monospace; font-weight:600; font-size:16px; color:var(--ink); }
  .add-btn{
    background:var(--navy);
    color:#fff;
    padding:8px 14px;
    border-radius:8px;
    font-size:12.5px;
    font-weight:600;
    transition:background .15s ease, transform .1s ease;
  }
  .add-btn:hover{ background:var(--amber-deep); color:var(--navy); }
  .add-btn.added{ background:var(--green); color:#fff; }
  .add-btn:active{ transform:scale(0.94); }

  .empty-state{
    text-align:center;
    padding:60px 20px;
    color:var(--muted);
  }

  /* ===== Floating buttons ===== */
  .floating-stack{
    position:fixed;
    right:18px;
    bottom:18px;
    z-index:60;
    display:flex;
    flex-direction:column;
    gap:12px;
    align-items:flex-end;
  }
  .fab{
    width:56px; height:56px;
    border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    box-shadow:var(--shadow-lg);
    position:relative;
    transition:transform .15s ease;
  }
  .fab:active{ transform:scale(0.92); }
  .fab-cart{ background:var(--amber); color:var(--navy); }
  .fab-whatsapp{ background:#25D366; color:#fff; }
  .fab-badge{
    position:absolute;
    top:-4px; right:-4px;
    background:var(--danger);
    color:#fff;
    font-size:11px;
    font-weight:700;
    min-width:20px; height:20px;
    border-radius:10px;
    display:flex; align-items:center; justify-content:center;
    font-family:'JetBrains Mono', monospace;
    border:2px solid var(--paper);
  }

  /* ===== Modal / Drawer shared ===== */
  .overlay{
    position:fixed; inset:0;
    background:rgba(11,18,32,0.5);
    z-index:80;
    opacity:0;
    pointer-events:none;
    transition:opacity .2s ease;
  }
  .overlay.open{ opacity:1; pointer-events:auto; }

  .drawer{
    position:fixed;
    right:0; top:0; bottom:0;
    width:min(420px, 100vw);
    background:var(--paper);
    z-index:90;
    transform:translateX(100%);
    transition:transform .28s cubic-bezier(.32,.72,0,1);
    display:flex;
    flex-direction:column;
    box-shadow:-10px 0 40px rgba(0,0,0,0.2);
  }
  .drawer.open{ transform:translateX(0); }
  .drawer-header{
    background:var(--navy);
    color:#fff;
    padding:18px 20px;
    display:flex;
    align-items:center;
    justify-content:space-between;
  }
  .drawer-header h3{ font-size:17px; font-weight:700; }
  .close-btn{
    background:rgba(255,255,255,0.1);
    color:#fff;
    width:32px; height:32px;
    border-radius:8px;
    display:flex; align-items:center; justify-content:center;
    font-size:18px;
    line-height:1;
  }
  .drawer-body{
    flex:1;
    overflow-y:auto;
    padding:16px 20px;
  }
  .drawer-footer{
    padding:16px 20px 20px;
    background:var(--card);
    border-top:1px solid var(--line);
  }

  .cart-item{
    display:flex;
    gap:12px;
    padding:12px 0;
    border-bottom:1px solid var(--line);
  }
  .cart-item img{
    width:64px; height:64px;
    border-radius:10px;
    object-fit:cover;
    flex-shrink:0;
    background:var(--card);
  }
  .cart-item-info{ flex:1; min-width:0; }
  .cart-item-info h5{ font-size:14px; font-weight:600; margin-bottom:2px; }
  .cart-item-info .unit-price{ font-size:12px; color:var(--muted); font-family:'JetBrains Mono', monospace; }
  .qty-row{ display:flex; align-items:center; gap:10px; margin-top:8px; }
  .qty-btn{
    width:26px; height:26px;
    border-radius:7px;
    background:var(--paper);
    border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center;
    font-weight:700;
    font-size:14px;
    color:var(--ink);
  }
  .qty-btn:hover{ background:var(--line); }
  .qty-val{ font-family:'JetBrains Mono', monospace; font-weight:600; min-width:18px; text-align:center; font-size:13.5px; }
  .remove-link{
    font-size:11.5px;
    color:var(--danger);
    font-weight:600;
    margin-left:auto;
  }
  .cart-item-total{
    font-family:'JetBrains Mono', monospace;
    font-weight:700;
    font-size:14px;
    white-space:nowrap;
  }

  .totals-row{
    display:flex;
    justify-content:space-between;
    font-size:14px;
    color:var(--muted);
    margin-bottom:6px;
  }
  .totals-row.grand{
    font-size:18px;
    font-weight:700;
    color:var(--ink);
    margin-top:10px;
    padding-top:10px;
    border-top:1px dashed var(--line);
  }
  .totals-row.grand .amt{ font-family:'JetBrains Mono', monospace; }

  .form-field{ margin-bottom:14px; }
  .form-field label{
    display:block;
    font-size:12.5px;
    font-weight:600;
    color:var(--muted);
    margin-bottom:6px;
  }
  .form-field label .req{ color:var(--danger); }
  .form-field input, .form-field textarea{
    width:100%;
    padding:11px 12px;
    border-radius:9px;
    border:1px solid var(--line);
    background:var(--card);
    font-family:inherit;
    font-size:14px;
    color:var(--ink);
  }
  .form-field input:focus, .form-field textarea:focus{
    outline:2px solid var(--amber);
    outline-offset:1px;
    border-color:var(--amber-deep);
  }
  .form-field textarea{ resize:vertical; min-height:70px; }

  .full-btn{
    width:100%;
    padding:14px;
    border-radius:11px;
    background:var(--navy);
    color:#fff;
    font-weight:700;
    font-size:15px;
    display:flex; align-items:center; justify-content:center; gap:8px;
    transition:background .15s ease;
  }
  .full-btn:hover{ background:var(--amber-deep); color:var(--navy); }
  .full-btn:disabled{ opacity:0.6; cursor:not-allowed; }

  .order-summary-box{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:10px;
    padding:12px 14px;
    margin-bottom:16px;
    font-size:13px;
  }
  .order-summary-box .line{
    display:flex;
    justify-content:space-between;
    padding:4px 0;
    color:var(--muted);
  }
  .order-summary-box .line b{ color:var(--ink); font-weight:600; }

  .success-screen{
    text-align:center;
    padding:30px 10px;
  }
  .success-icon{
    width:64px; height:64px;
    border-radius:50%;
    background:rgba(30,158,107,0.12);
    color:var(--green);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 16px;
    font-size:30px;
  }
  .success-screen h4{ font-size:18px; margin-bottom:8px; }
  .success-screen p{ color:var(--muted); font-size:14px; margin-bottom:18px; line-height:1.5; }

  .toast{
    position:fixed;
    bottom:90px;
    left:50%;
    transform:translateX(-50%) translateY(20px);
    background:var(--ink);
    color:#fff;
    padding:11px 18px;
    border-radius:10px;
    font-size:13.5px;
    font-weight:500;
    z-index:100;
    opacity:0;
    pointer-events:none;
    transition:all .25s ease;
    box-shadow:var(--shadow-lg);
  }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

  footer{
    background:var(--navy);
    color:#B7C0D6;
    text-align:center;
    padding:26px 20px 30px;
    font-size:12.5px;
    line-height:1.7;
  }
  footer b{ color:#fff; }

  @media (prefers-reduced-motion: reduce){
    *{ transition:none !important; animation:none !important; scroll-behavior:auto !important; }
  }
</style>
</head>
